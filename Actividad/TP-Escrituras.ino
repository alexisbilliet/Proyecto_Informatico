 pinMode(rojo1, OUTPUT);
 pinMode(verde1, OUTPUT);
 pinMode(rojo2, OUTPUT);
 pinMode(azul2, OUTPUT);
 pinMode(verde2, OUTPUT);
 pinMode(azul3, OUTPUT);
